pipeline {
    agent any

    environment {
        GITHUB_REPO        = 'AbdulHannan188/check_deploy'
        GITHUB_CREDENTIALS = 'github-token'
        SOURCE_BRANCH      = 'dev'
        TARGET_BRANCH      = 'main'
        PYTHON_VERSION     = 'python3'
        VENV_DIR           = 'selenium_tests/.venv'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    triggers {
        githubPush()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_COMMIT_SHORT = sh(
                        script: 'git rev-parse --short HEAD',
                        returnStdout: true
                    ).trim()
                    // ── Capture pusher email ──────────────────────────
                    env.PUSHER_EMAIL = sh(
                        script: 'git log -1 --format="%ae"',
                        returnStdout: true
                    ).trim()
                }
                echo "▶ Commit: ${env.GIT_COMMIT_SHORT}"
                echo "▶ Pushed by: ${env.PUSHER_EMAIL}"
            }
        }

        stage('Setup Python Environment') {
            steps {
                sh """
                    ${PYTHON_VERSION} -m venv ${VENV_DIR}
                    . ${VENV_DIR}/bin/activate
                    pip install --upgrade pip
                    pip install -r selenium_tests/requirements.txt
                """
            }
        }

        stage('Run Tests') {
            steps {
                sh """
                    npm install
                    npm run dev -- --host 0.0.0.0 --port 5173 &
                    echo \$! > vite.pid

                    echo "Waiting for Vite on port 5173..."
                    for i in \$(seq 1 30); do
                        if nc -z localhost 5173 2>/dev/null; then
                            echo "✅ Vite is up!"
                            break
                        fi
                        echo "  [\$i/30] waiting 2s..."
                        sleep 2
                    done

                    nc -z localhost 5173 || { echo "❌ Vite never started!"; exit 1; }

                    . ${VENV_DIR}/bin/activate
                    BASE_URL=http://localhost:5173 pytest selenium_tests/tests/ \
                        --junitxml=selenium_tests/test-results/results.xml \
                        --html=selenium_tests/test-results/report.html \
                        --self-contained-html \
                        -v
                """
            }
            post {
                always {
                    sh "[ -f vite.pid ] && kill \$(cat vite.pid) 2>/dev/null || true"
                    sh 'rm -f vite.pid'
                    junit allowEmptyResults: true,
                          testResults: 'selenium_tests/test-results/results.xml'
                    publishHTML(target: [
                        allowMissing         : false,
                        alwaysLinkToLastBuild: true,
                        keepAll              : true,
                        reportDir            : 'selenium_tests/test-results',
                        reportFiles          : 'report.html',
                        reportName           : 'Pytest Report'
                    ])
                }
            }
        }

        stage('Merge dev → main') {
            when {
                expression {
                    env.GIT_BRANCH == "origin/${SOURCE_BRANCH}" ||
                    env.BRANCH_NAME == "${SOURCE_BRANCH}"
                }
            }
            steps {
                script {
                    withCredentials([usernamePassword(
                        credentialsId: "${GITHUB_CREDENTIALS}",
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_TOKEN'
                    )]) {
                        sh """
                            git config user.email "jenkins@ci.local"
                            git config user.name  "Jenkins CI"

                            git remote set-url origin \
                                https://\${GIT_USER}:\${GIT_TOKEN}@github.com/${GITHUB_REPO}.git

                            git fetch origin

                            git checkout -B ${TARGET_BRANCH} origin/${TARGET_BRANCH}
                            git merge --no-ff origin/${SOURCE_BRANCH} \
                                -m "CI: merge ${SOURCE_BRANCH} → ${TARGET_BRANCH} ✅ tests passed [${env.GIT_COMMIT_SHORT}]"

                            git push origin ${TARGET_BRANCH}
                        """
                    }
                }
                echo "✅ ${SOURCE_BRANCH} merged into ${TARGET_BRANCH}"
            }
        }
    }

    post {
        success {
            echo "✅ Pipeline SUCCESS — code merged to ${TARGET_BRANCH}"
        }

        failure {
            script {
                if (!env.PUSHER_EMAIL) {
                    env.PUSHER_EMAIL = sh(
                        script: 'git log -1 --format="%ae"',
                        returnStdout: true
                    ).trim()
                }
            }
            emailext(
                to: "${env.PUSHER_EMAIL}",
                subject: "❌ Jenkins Build FAILED — ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                    <html>
                    <body>
                        <h2 style="color:red;">❌ Build Failed — Tests Did Not Pass</h2>
                        <table border="1" cellpadding="8" cellspacing="0">
                            <tr><td><b>Job</b></td><td>${env.JOB_NAME}</td></tr>
                            <tr><td><b>Build Number</b></td><td>#${env.BUILD_NUMBER}</td></tr>
                            <tr><td><b>Branch</b></td><td>${SOURCE_BRANCH}</td></tr>
                            <tr><td><b>Commit</b></td><td>${env.GIT_COMMIT_SHORT}</td></tr>
                            <tr><td><b>Pushed By</b></td><td>${env.PUSHER_EMAIL}</td></tr>
                            <tr><td><b>Status</b></td><td style="color:red;">FAILED</td></tr>
                        </table>
                        <br/>
                        <p>⚠️ Your code was <b>NOT merged</b> into <b>${TARGET_BRANCH}</b> because tests failed.</p>
                        <p>Please fix the failing tests and push again.</p>
                        <br/>
                        <a href="${env.BUILD_URL}">👉 Click here to see full build logs</a>
                        <br/><br/>
                        <p style="color:gray;">— Jenkins CI</p>
                    </body>
                    </html>
                """,
                mimeType: 'text/html',
                attachLog: true
            )
        }

        cleanup {
            sh "rm -rf ${VENV_DIR} selenium_tests/test-results"
        }
    }
}
